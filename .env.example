# On Vercel, use Neon's POOLED connection string (host contains "-pooler") for runtime.
# Neon also sets POSTGRES_URL_NON_POOLING — used automatically at build time for migrations.
DATABASE_URL=postgres://USER@localhost:5432/malayalam_news
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Public site URL. Required on Vercel for Payload admin + Blob client uploads (CORS).
# Production example: https://newstoday-ecru.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Media storage. Unset in dev → local disk. On Vercel: Storage → Blob (auto-sets this).
# Must be a real token from the Vercel dashboard — NOT the build-time placeholder in package.json.
# Use a PUBLIC Blob store — Payload's adapter does not support private stores.
BLOB_READ_WRITE_TOKEN=

# Email (optional in dev — logs to console if unset). Set all to enable real sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=news@newstoday.test

# Analytics (optional). GA4 loads only after cookie consent.
NEXT_PUBLIC_GA_ID=

# Google AdSense (optional). Ads load only after cookie consent.
# Slot ids come from your AdSense account; ads render only when client + slot are set.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_HOME=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=

# Metered paywall: free premium articles before the wall (default 3).
NEXT_PUBLIC_PAYWALL_FREE_LIMIT=3

# Web push (optional). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:news@newstoday.test

# Error monitoring (optional). No-op unless set.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
