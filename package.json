{
  "name": "newstoday",
  "version": "1.0.0",
  "description": "Malayalam-first news portal (ml default, /en) built on Payload 3 + Next.js",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env BLOB_READ_WRITE_TOKEN=importmap NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@indic-transliteration/sanscript": "^1.3.3",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/email-nodemailer": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-vercel-blob": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@sentry/nextjs": "^10.63.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "any-ascii": "^0.3.3",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.7",
    "payload": "3.85.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.7",
    "prettier": "^3.4.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "22.x",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
